rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/lojistas/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/lojistas/$(request.auth.uid)).data.role == 'admin';
    }

    match /marketplace/{folder}/{userId}/{fileName} {
      allow read: if true;
      allow write: if isAdmin() || (signedIn() && request.auth.uid == userId);
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
